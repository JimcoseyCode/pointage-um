// prisma/schema.prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL") // À définir dans ton fichier .env
}

// Définis un enum pour les rôles
enum Role {
  admin
  manager
  responsable
  employe
}

model User {
  id          String    @id @default(auto()) @map("_id") @db.ObjectId
  name        String
  firstName   String
  email       String    @unique
  password    String
  phoneNumber String
  role        Role      // Utilise l'enum Role pour le champ role
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}